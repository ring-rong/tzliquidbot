# Токен Telegram-бота от @BotFather. Секрет — реальное значение только в .env
# (в .gitignore), никогда не коммитить.
BOT_TOKEN=

# URL Mock-CRM, POST /v1/leads. Публичный мок-эндпоинт, сам по себе не секрет,
# но всё равно конфиг, а не хардкод в коде (CLAUDE.md, правило 1.7).
CRM_ENDPOINT_URL=

# Необязательные — в app/config.py уже есть дефолты, совпадающие с ТЗ.
# Переопределяйте только если знаете, зачем.
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=3
CRM_REQUEST_TIMEOUT_SECONDS=10

# Redis для FSM-состояний — переживает перезапуск/пересборку контейнера бота
# (сам Redis живёт отдельным сервисом в docker-compose.yml с именованным томом).
# Дефолт рассчитан на docker compose (хост "redis" — имя сервиса). Для локального
# запуска без Docker (раздел 4 README) поднимите Redis отдельно и укажите свой адрес,
# например redis://localhost:6379/0.
REDIS_URL=redis://redis:6379/0
